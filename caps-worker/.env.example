# CAPS Worker 환경 설정
# 이 파일을 .env로 복사 후 값을 채워주세요

# Access DB 파일 경로
CAPS_DB_PATH=C:\Caps\ACServer\ACCESS.mdb

# Access DB 비밀번호 (AccessPassView 등으로 확인)
CAPS_DB_PASSWORD=

# MES 서버 URL
MES_URL=https://webapp-9i0.pages.dev
# 로컬 테스트 시: MES_URL=http://192.168.0.94:3000

# MES CAPS 워커 API 키 (MES 설정 > CAPS 연동에서 확인)
MES_API_KEY=

# 동기화 주기 (cron 표현식, 기본 15분)
SYNC_CRON=*/15 * * * *

# 조회 범위 (오늘 기준 며칠 전까지, 기본 2)
LOOKBACK_DAYS=2

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info
